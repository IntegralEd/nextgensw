# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real PATs.

# Airtable base for NextGen SW
# https://airtable.com/appAWSOlM2P9kqgOV
AIRTABLE_BASE_ID=appAWSOlM2P9kqgOV

# Read-scoped PAT for local sessions (curl tasks/feedback/screenshots)
# Create at https://airtable.com/create/tokens with scope:
#   data.records:read   on the NextGen SW base only
AIRTABLE_PAT_READ=

# Write-scoped PAT — DO NOT put in .env.local; this lives in Netlify env vars only.
# Listed here for documentation; left blank locally.
AIRTABLE_PAT_WRITE=
